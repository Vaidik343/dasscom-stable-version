{
  "name": "dasscom-configuration-tool",
  "version": "1.0.0",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 5173",
    "electron": "cross-env NODE_ENV=development electron .",
    "electron-dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development npm run electron\"",
    "dist": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "bootstrap": "^5.3.8",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "exceljs": "^4.4.0",
    "ip": "^2.0.1",
    "lottie-react": "^2.4.1",
    "pin": "^0.3.0",
    "ping": "^0.4.4",
    "react": "^19.1.1",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.1.1",
    "uninstall": "^0.0.0"
  },
  "keywords": [],
  "description": "Network Management Tool.",
  "author": "Dasscom Innovative Sound",
  "homepage": "https://dasscom.com",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^38.1.2",
    "electron-builder": "^26.0.12",
    "electron-icon-builder": "^2.0.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "png-to-ico": "^3.0.1",
    "vite": "^7.1.7",
    "wait-on": "^9.0.1"
  },
  "build": {
    "appId": "com.dasscom.networktool.v2",
    "productName": "Dasscom Configuration Tool",
    "copyright": "Copyright © 2026 Dasscom Innovative Sound",
    "files": [
      "dist/**",
      "src/**",
      "preload/**",
      "api/**",
      "utils/**",
      "public/**"
    ],
    "asarUnpack": [
      "binaries/**"
    ],
    "extraResources": [
      {
        "from": "binaries",
        "to": "binaries"
      },
      {
        "from": "build/icons/cropped-black-icon.ico",
        "to": "cropped-black-icon.ico"
      }
    ],
    "npmRebuild": false,
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "icon": "build/icons/cropped-black-icon.ico",
      "forceCodeSigning": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": true
    },
    "nsis": {
      "include": "build/installer.nsh",
      "installerIcon": "build/icons/cropped-black-icon.ico",
      "uninstallerIcon": "build/icons/cropped-black-icon.ico",
      "installerHeaderIcon": "build/icons/cropped-black-icon.ico",
      "uninstallDisplayName": "Dasscom Configuration Tool",
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    }
  }
}